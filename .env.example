# ============================================================
# Go Backend — copy this file to .env and fill in real values.
# NEVER commit .env — it is listed in .gitignore.
# ============================================================

# JWT signing secret. Use a strong random string (min 32 chars).
# Generate one: openssl rand -hex 32
JWT_SECRET=

# Python AI brain service
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_KEY=

# Optional overrides (defaults shown)
PORT=8080
CORS_ORIGINS=http://localhost:5173
# DATABASE_URL=postgres://user:pass@host/dbname   # leave unset to use SQLite
# DB_PATH=expenses.db                              # SQLite file path (default: expenses.db)
